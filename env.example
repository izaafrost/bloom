# Kopiér denne fil til ".env" og udfyld.
# VIGTIGT: Den private nøgle skal holdes HEMMELIG — del den aldrig og
# læg den ikke i et offentligt repo. Generér dit eget nøglepar med:
#   npm run keys

VAPID_PUBLIC_KEY=din-offentlige-vapid-noegle
VAPID_PRIVATE_KEY=din-private-vapid-noegle
VAPID_SUBJECT=mailto:dig@eksempel.dk

# Valgfrit:
PORT=3000
# Lås CORS til din app-adresse (anbefales i produktion):
# ALLOW_ORIGIN=https://dit-brugernavn.github.io
